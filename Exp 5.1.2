# Read input: four space-separated integers
marks = list(map(int, input().split()))

# Calculate total marks
total_marks = sum(marks)

# Calculate aggregate percentage
aggregate_percentage = (total_marks / 400) * 100

# Determine grade based on aggregate percentage
if aggregate_percentage >= 75:
    grade = "Distinction"
elif 60 <= aggregate_percentage < 75:
    grade = "First Division"
elif 50 <= aggregate_percentage < 60:
    grade = "Second Division"
elif 40 <= aggregate_percentage < 50:
    grade = "Third Division"
else:
    grade = "Fail"

# Print the results
print(total_marks)
print(f"{aggregate_percentage:.2f}")
print(grade)

